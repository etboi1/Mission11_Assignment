{
  "openapi": "3.1.1",
  "info": {
    "title": "Mission11_Assignment | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:5000"
    },
    {
      "url": "http://localhost:4000"
    }
  ],
  "paths": {
    "/api/Bookstore": {
      "get": {
        "tags": [
          "Bookstore"
        ],
        "operationId": "GetBooks",
        "parameters": [
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 5
            }
          },
          {
            "name": "pageNum",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "none"
            }
          },
          {
            "name": "bookCategories",
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Bookstore/GetBookCategories": {
      "get": {
        "tags": [
          "Bookstore"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Bookstore"
    }
  ]
}